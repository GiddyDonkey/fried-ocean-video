# ── Vercel (frontend + /api/generate serverless function) ──────────────────────
# Set these in Vercel dashboard → Project → Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...

# ── Railway (build-video.js video server) ──────────────────────────────────────
# These are already in your Railway environment from Catapultor
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=3001

# ── Optional: point Vercel frontend at Railway video builder ───────────────────
# Add this in Vercel env vars so the frontend can trigger Railway builds
NEXT_PUBLIC_VIDEO_BUILDER_URL=https://your-railway-app.railway.app
