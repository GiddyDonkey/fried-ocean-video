{
  "version": 2,
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/creatomate", "dest": "/api/creatomate.js" },
    { "src": "/api/scrape", "dest": "/api/scrape.js" },
    { "src": "/", "dest": "/index.html" }
  ],
  "functions": {
    "api/generate.js": { "maxDuration": 60 },
    "api/creatomate.js": { "maxDuration": 60 },
    "api/scrape.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com; default-src 'self' 'unsafe-inline' https: data:;" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
